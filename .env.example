# ==============================================================================
# FICHIER D'EXEMPLE DES VARIABLES D'ENVIRONNEMENT
# Copiez ce fichier, renommez-le en ".env" et remplacez les valeurs manquantes.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Base de données (PostgreSQL via Docker)
# ------------------------------------------------------------------------------
POSTGRES_USER="votre_utilisateur_local"
POSTGRES_PASSWORD="votre_mot_de_passe_local"
POSTGRES_DB="nom_de_votre_base"
# L'URL utilisée par Prisma pour se connecter à la base
DATABASE_URL="postgresql://votre_utilisateur_local:votre_mot_de_passe_local@localhost:5432/nom_de_votre_base?schema=public"

# ------------------------------------------------------------------------------
# 2. Authentification (Auth.js / NextAuth)
# ------------------------------------------------------------------------------
# L'URL de base de votre application (généralement localhost en dev)
NEXTAUTH_URL="http://localhost:3000"

# Clé secrète pour chiffrer les sessions JWT
# (Générez-en une via la commande terminal : openssl rand -base64 32 ou npx auth secret)
AUTH_SECRET="votre_cle_secrete_generee_ici"

# ------------------------------------------------------------------------------
# 3. Envoi d'emails (SMTP - Mailtrap pour le développement)
# ------------------------------------------------------------------------------
# Récupérez ces identifiants dans les paramètres SMTP de votre Inbox Mailtrap
EMAIL_SERVER_USER="identifiant_mailtrap_ici"
EMAIL_SERVER_PASSWORD="mot_de_passe_mailtrap_ici"
EMAIL_SERVER_HOST="sandbox.smtp.mailtrap.io"
EMAIL_SERVER_PORT="2525"
EMAIL_FROM="noreply@slash.xyz"